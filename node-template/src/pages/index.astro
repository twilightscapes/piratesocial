---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { siteConfig, withBase, cleanSlug } from '../lib/config';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const posts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 12);
---

<BaseLayout>
  <!-- Hero / Profile -->
  <section class="mb-12 flex flex-col items-center text-center md:flex-row md:text-left md:gap-8">
    <img
      src={siteConfig.avatar}
      alt={siteConfig.author}
      class="h-32 w-32 rounded-full border-2 border-theme-border object-cover"
    />
    <div class="mt-4 md:mt-0">
      <h1 class="text-3xl font-bold font-heading">{siteConfig.author}</h1>
      <p class="mt-2 max-w-lg text-theme-muted">{siteConfig.bio}</p>
      {siteConfig.camera && (
        <p class="mt-1 text-sm text-theme-faint">📷 {siteConfig.camera}</p>
      )}
      {siteConfig.location && (
        <p class="mt-1 text-sm text-theme-faint">📍 {siteConfig.location}</p>
      )}
    </div>
  </section>

  <!-- Recent Posts Grid -->
  <section>
    <h2 class="mb-6 text-xl font-semibold">Recent Photos</h2>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => (
        <a
          href={`${base}/posts/${cleanSlug(post.id)}`}
          class="group overflow-hidden rounded-lg border border-theme-card-border bg-theme-card transition hover:border-theme-card-hover"
        >
          {post.data.image && (
            <div class="aspect-[4/3] overflow-hidden">
              <img
                src={withBase(typeof post.data.image === 'string' ? post.data.image : post.data.image.src)}
                alt={post.data.imageAlt || post.data.title}
                class="h-full w-full object-cover transition group-hover:scale-105"
                loading="lazy"
              />
            </div>
          )}
          <div class="p-4">
            <h3 class="font-medium">{post.data.title}</h3>
            <time class="mt-1 text-xs text-theme-faint" datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            {post.data.tags.length > 0 && (
              <div class="mt-2 flex flex-wrap gap-1">
                {post.data.tags.slice(0, 3).map(tag => (
                  <span class="rounded bg-theme-tag px-2 py-0.5 text-xs text-theme-tag-text">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>
    <div class="mt-8 text-center">
      <a href={`${base}/posts`} class="text-sm text-theme-muted underline hover:text-theme-text">View all posts →</a>
    </div>
  </section>
</BaseLayout>
