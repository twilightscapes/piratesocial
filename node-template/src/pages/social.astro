    document.querySelectorAll('.view-squad-feed-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const feedEl = document.querySelector(`.squad-feed[data-squad-id="${btn.dataset.squadId}"]`);
        if (!feedEl.classList.contains('hidden')) {
          feedEl.classList.add('hidden');
          btn.textContent = 'View Squad Feed';
          return;
        }
        const squad = allSquads.find(s => String(s.id) === btn.dataset.squadId);
        if (!squad || !squad.members.length) return;
        btn.textContent = L.loading;
        try {
          const posts = await fetchSquadFeedDirect(squad.members);
          feedEl.innerHTML = posts.map(post => renderSquadCard(post)).join('') || `<div class="text-center py-4 text-theme-faint">${L.noPosts}</div>`;
          feedEl.classList.remove('hidden');
          btn.textContent = 'Hide Squad Feed';
          initHlsVideos();
        } catch {
          feedEl.innerHTML = `<div class="text-center py-4 text-red-400">${L.failedToLoad}</div>`;
          feedEl.classList.remove('hidden');
          btn.textContent = 'Hide Squad Feed';
        }
      });
    });

    document.querySelectorAll('.squad-member-avatar').forEach(el => {
      el.addEventListener('click', async () => {
        const handle = el.dataset.handle;
        const squadEl = el.closest('[data-squad-id]');
        const feedEl = squadEl.querySelector('.squad-feed');
        const feedBtn = squadEl.querySelector('.view-squad-feed-btn');
        if (!feedEl || !feedBtn) return;
        feedBtn.textContent = `Loading @${handle}...`;
        try {
          const data = await fetchAuthorFeedDirect(handle, 10);
          feedEl.innerHTML = data.map(post => renderSquadCard(post)).join('') || `<div class="text-center py-4 text-theme-faint">${L.noPosts}</div>`;
          feedEl.classList.remove('hidden');
          feedBtn.textContent = 'Hide Squad Feed';
          initHlsVideos();
        } catch {
          feedEl.innerHTML = `<div class="text-center py-4 text-red-400">${L.failedToLoad}</div>`;
          feedEl.classList.remove('hidden');
          feedBtn.textContent = 'Hide Squad Feed';
        }
      });
    });
  }

  function renderSquadCard(post) {
    const embed = post.embedData || {};
    let embedHtml = '';
    if (embed.images?.length > 1) {
      embedHtml += `<div class="grid grid-cols-2 gap-1 mt-2 rounded overflow-hidden">
        ${embed.images.map(img => `<img src="${escapeHtml(img.fullsize || img.thumb)}" alt="${escapeHtml(img.alt || '')}" class="w-full object-cover aspect-square" loading="lazy" onerror="this.style.display='none'" />`).join('')}
      </div>`;
    }
    if (embed.images?.length === 1) {
      embedHtml += `<div class="mt-2 bg-black flex justify-center rounded overflow-hidden"><img src="${escapeHtml(embed.images[0].fullsize || embed.images[0].thumb)}" alt="${escapeHtml(embed.images[0].alt || '')}" style="width:100%;max-height:20rem;object-fit:contain" loading="lazy" onerror="this.parentElement.style.display='none'" /></div>`;
    }
    if (embed.video?.playlist) {
      embedHtml += `<div class="mt-2 rounded overflow-hidden bg-black aspect-video">
        <video controls preload="none" poster="${escapeHtml(embed.video.thumb || '')}" class="w-full h-full" data-hls="${escapeHtml(embed.video.playlist)}"></video>
      </div>`;
    }
    if (embed.external?.uri) {
      const ytId = getYouTubeId(embed.external.uri);
      if (ytId) {
        embedHtml += `<div class="mt-2 rounded overflow-hidden bg-black aspect-video"><iframe src="https://www.youtube.com/embed/${ytId}" class="w-full h-full" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe></div>`;
      } else {
        embedHtml += `<a href="${escapeHtml(embed.external.uri)}" target="_blank" rel="noopener noreferrer" class="mt-2 block rounded border border-theme-input-border overflow-hidden hover:border-theme-card-hover transition">
          ${embed.external.thumb ? `<img src="${escapeHtml(embed.external.thumb)}" alt="" class="w-full aspect-[2/1] object-cover" loading="lazy" onerror="this.style.display='none'" />` : ''}
          <div class="p-3"><div class="text-sm font-medium text-theme-text line-clamp-1">${escapeHtml(embed.external.title || '')}</div></div>
        </a>`;
      }
    }
    if (embed.quote?.text) {
      embedHtml += `<div class="mt-2 rounded border border-theme-input-border p-3 bg-theme-surface/50">
        <div class="text-xs text-theme-muted mb-1"><span class="font-medium text-theme-text">${escapeHtml(embed.quote.author)}</span> <span class="text-theme-faint">@${escapeHtml(embed.quote.handle)}</span></div>
        <p class="text-sm text-theme-text line-clamp-3">${escapeHtml(embed.quote.text)}</p>
      </div>`;
    }
    return `
    <article class="rounded-lg border border-theme-card-border bg-theme-card/50 p-4">
      <div class="flex items-center gap-2 mb-2">
        ${post.author.avatar ? `<img src="${escapeHtml(post.author.avatar)}" class="h-8 w-8 rounded-full" />` : ''}
        <div>
          <span class="text-sm font-medium">${escapeHtml(post.author.displayName)}</span>
          <span class="text-xs text-theme-faint ml-1">@${escapeHtml(post.author.handle)}</span>
        </div>
        <time class="text-xs text-theme-faint ml-auto">${timeAgo(post.pubDate)}</time>
      </div>
      ${post.text ? `<p class="text-sm whitespace-pre-wrap">${escapeHtml(post.text)}</p>` : ''}
      ${embedHtml}
      <div class="mt-2 flex items-center gap-3 text-xs text-theme-faint">
        <span>♡ ${post.likeCount}</span>
        <span>🔁 ${post.repostCount}</span>
        <span>💬 ${post.replyCount}</span>
        <a href="${escapeHtml(post.link)}" target="_blank" class="hover:text-theme-text ml-auto">↗ Open</a>
      </div>
    </article>`;
  }

  function formatWindow(minutes) {
    if (minutes < 60) return `${minutes}m`;
    const h = Math.floor(minutes / 60);
    const m = minutes % 60;
    return m ? `${h}h ${m}m` : `${h}h`;
  }

  function timeAgo(dateStr) {
    if (!dateStr) return 'never';
    const seconds = Math.floor((Date.now() - new Date(dateStr).getTime()) / 1000);
    if (seconds < 60) return 'just now';
    const minutes = Math.floor(seconds / 60);
    if (minutes < 60) return `${minutes}m ago`;
    const hours = Math.floor(minutes / 60);
    if (hours < 24) return `${hours}h ago`;
    const days = Math.floor(hours / 24);
    return `${days}d ago`;
  }

  // Auto-load if signed in
  if (token) {
    // Fetch Bluesky handle in background for public API fallback & squads
    initSquadsProfile();
    loadFeed();
  }
</script>

