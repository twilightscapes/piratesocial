---
import BaseLayout from '../layouts/BaseLayout.astro';
import home from '../data/home.json';
import ProfileBlock from '../components/blocks/ProfileBlock.astro';
import RecentPostsBlock from '../components/blocks/RecentPostsBlock.astro';
import HeroBlock from '../components/blocks/HeroBlock.astro';
import YouTubeBlock from '../components/blocks/YouTubeBlock.astro';
import GalleryBlock from '../components/blocks/GalleryBlock.astro';
import TextBlock from '../components/blocks/TextBlock.astro';
import ImageBlock from '../components/blocks/ImageBlock.astro';
import LocationBlock from '../components/blocks/LocationBlock.astro';

const blocks = home.blocks || [];
const hasLightbox = blocks.some((b: any) => b.type === 'gallery' || (b.type === 'image' && b.lightbox !== false));
---

<BaseLayout>
  {blocks.map((block: any) => (
    <>
      {block.type === 'hero' && <HeroBlock {...block} />}
      {block.type === 'profile' && <ProfileBlock {...block} />}
      {block.type === 'recentPosts' && <RecentPostsBlock {...block} />}
      {block.type === 'youtube' && <YouTubeBlock {...block} />}
      {block.type === 'gallery' && <GalleryBlock {...block} />}
      {block.type === 'text' && <TextBlock {...block} />}
      {block.type === 'image' && <ImageBlock {...block} />}
      {block.type === 'location' && <LocationBlock {...block} />}
    </>
  ))}

  {hasLightbox && (
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css" />
    <script is:inline src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        if (typeof GLightbox !== 'undefined') {
          GLightbox({ selector: '.glightbox', touchNavigation: true, loop: true });
        }
      });
    </script>
  )}
</BaseLayout>
