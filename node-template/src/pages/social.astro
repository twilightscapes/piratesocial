  async function loadSquads() {
    const container = document.getElementById('squads-list');
    const select = document.getElementById('squad-select');
    if (!container || !select) return;
    try {
      const res = await fetch(`${hubUrl}/api/bluesky-feed/squads`, {
        headers: { Authorization: `Bearer ${token}` },
      });
      allSquads = await res.json();

      // Preserve current selection
      const prevId = select.value;

      // Rebuild select options
      select.innerHTML = '<option value="">Select a squad...</option>' +
        allSquads.map(s => `<option value="${s.id}">${escapeHtml(s.name)} (${s.members.length})</option>`).join('');

      if (!allSquads.length) {
        container.innerHTML = '<div class="text-center py-8 text-theme-faint">No squads yet. Create one!</div>';
        return;
      }

      // Re-select previous or first
      const targetId = prevId && allSquads.find(s => String(s.id) === String(prevId)) ? prevId : String(allSquads[0].id);
      select.value = targetId;
      showSquad(targetId);
    } catch {
      container.innerHTML = `<div class="text-center py-8 text-red-400">${L.failedToLoad}</div>`;
    }
  }

