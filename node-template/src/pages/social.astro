      myHandle = session?.handle || null;
      if (myHandle) {
        const profileRes = await fetchWithTimeout(`https://public.api.bsky.app/xrpc/app.bsky.actor.getProfile?actor=${encodeURIComponent(myHandle)}`, {}, 8000);
