---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../lib/config';
import labels from '../data/labels.json';
const sl = labels.social;
---

<BaseLayout title="Social">
  <div class="mx-auto max-w-3xl">
    <div class="sticky top-[41px] md:top-[57px] z-30 -mx-4 px-3 py-2 md:px-4 md:py-4 mb-4 md:mb-8 flex items-center justify-between bg-theme-bg/95 backdrop-blur supports-[backdrop-filter]:bg-theme-bg/80 border-b border-theme-border">
      <h1 class="text-lg md:text-2xl font-bold font-heading whitespace-nowrap mr-3">{sl.heading}</h1>
      <div class="flex gap-1 md:gap-2">
        <button id="tab-squads" class="rounded bg-theme-input-bg px-2 py-1 text-xs md:px-3 md:py-1.5 md:text-sm hover:bg-theme-surface-hover transition">
          {sl.tabSquads}
        </button>
        <button id="tab-timeline" class="rounded bg-theme-input-bg px-2 py-1 text-xs md:px-3 md:py-1.5 md:text-sm hover:bg-theme-surface-hover transition active-tab">
          {sl.tabTimeline}
        </button>
        <button id="tab-bluesky" class="rounded bg-theme-input-bg px-2 py-1 text-xs md:px-3 md:py-1.5 md:text-sm hover:bg-theme-surface-hover transition">
          {sl.tabBluesky}
        </button>
        <button id="tab-discover" class="rounded bg-theme-input-bg px-2 py-1 text-xs md:px-3 md:py-1.5 md:text-sm hover:bg-theme-surface-hover transition">
          {sl.tabDiscover}
        </button>
        <button id="tab-people" class="rounded bg-theme-input-bg px-2 py-1 text-xs md:px-3 md:py-1.5 md:text-sm hover:bg-theme-surface-hover transition">
          {sl.tabPeople}
        </button>
      </div>
    </div>

    <!-- Timeline container -->
    <div id="feed-container" class="space-y-6">
      <div class="text-center text-theme-faint py-12">
        <p>{sl.signInPrompt}</p>
        <button id="social-login" class="mt-4 rounded bg-theme-primary text-white px-4 py-2 text-sm font-medium hover:bg-theme-primary-hover transition">
          {sl.signInButton}
        </button>
      </div>
    </div>

    <!-- Scroll sentinel for infinite scroll -->
    <div id="scroll-sentinel" class="mt-8 flex justify-center py-4 hidden">
      <div class="loader-spinner h-6 w-6 border-2 border-theme-border border-t-theme-muted rounded-full animate-spin"></div>
    </div>
  </div>
</BaseLayout>

<script is:inline src="https://cdn.jsdelivr.net/npm/hls.js@latest/dist/hls.min.js"></script>
<script is:inline define:vars={{ hubUrl: siteConfig.hubUrl, L: labels.social }}>
  const token = localStorage.getItem('ps_token');
  const feedContainer = document.getElementById('feed-container');
  const scrollSentinel = document.getElementById('scroll-sentinel');

  let currentPage = 1;
  let currentTab = 'timeline';
  let bskyCursor = null;
  let isLoading = false;
  let hasMore = true;

  // Infinite scroll via IntersectionObserver
  const scrollObserver = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting && !isLoading && hasMore) {
      currentPage++;
      loadFeed(true);
    }
  }, { rootMargin: '400px' });
  scrollObserver.observe(scrollSentinel);

  function fetchWithTimeout(url, opts = {}, ms = 8000) {
    const ctrl = new AbortController();
    const timer = setTimeout(() => ctrl.abort(), ms);
    return fetch(url, { ...opts, signal: ctrl.signal }).finally(() => clearTimeout(timer));
  }

  // --- Bluesky Session Management (browser-side, like skypost) ---
  let bskySession = null;

  function loadBskySession() {
    try {
      const stored = localStorage.getItem('ps_bsky_session');
      if (stored) bskySession = JSON.parse(stored);
    } catch { bskySession = null; }
    return bskySession;
  }

  function saveBskySession(session) {
    bskySession = session;
    localStorage.setItem('ps_bsky_session', JSON.stringify(session));
  }

  async function ensureBskySession() {
    // Return cached session if we have one
    if (bskySession?.accessJwt) return bskySession;
    loadBskySession();
    if (bskySession?.accessJwt) return bskySession;

    // Get session from hub (hub calls createSession with stored app password)
    if (!token) return null;
    try {
      console.log('[PS] Fetching Bluesky session from hub...');
      const res = await fetchWithTimeout(`${hubUrl}/api/bluesky/session`, {
        headers: { Authorization: `Bearer ${token}` },
      }, 10000);
      console.log('[PS] Session response:', res.status);
      if (res.ok) {
        const data = await res.json();
        console.log('[PS] Got session for:', data.handle);
        saveBskySession(data);
        return data;
      }
      const errData = await res.json().catch(() => ({}));
      console.error('[PS] Session error:', res.status, errData.error);
    } catch (err) {
      console.error('[PS] Session fetch failed:', err.message);
    }
    return null;
  }

  async function refreshBskySession() {
    if (!bskySession?.refreshJwt) return null;
    try {
      const res = await fetchWithTimeout('https://bsky.social/xrpc/com.atproto.server.refreshSession', {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${bskySession.refreshJwt}` },
      }, 8000);
      if (res.ok) {
        const data = await res.json();
        bskySession.accessJwt = data.accessJwt;
        if (data.refreshJwt) bskySession.refreshJwt = data.refreshJwt;
        saveBskySession(bskySession);
        return bskySession;
      } else {
        // Refresh failed — clear session and re-create from hub
        localStorage.removeItem('ps_bsky_session');
        bskySession = null;
        return ensureBskySession();
      }
    } catch {
      return null;
    }
  }

  // Tab switching
  document.querySelectorAll('[id^="tab-"]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelector('.active-tab')?.classList.remove('active-tab', 'bg-theme-surface-hover');
      btn.classList.add('active-tab', 'bg-theme-surface-hover');
      currentTab = btn.id.replace('tab-', '');
      currentPage = 1;
      bskyCursor = null;
      hasMore = true;
      loadFeed();
    });
  });

  // Login button
  document.getElementById('social-login')?.addEventListener('click', () => {
    window.location.href = `${hubUrl}/api/auth/github`;
  });

  async function loadFeed(append = false) {
    if (isLoading) return;
    isLoading = true;
    if (!append) {
      feedContainer.innerHTML = `<div class="text-center py-8 text-theme-faint">${L.loading}</div>`;
      hasMore = true;
    }
    scrollSentinel.classList.toggle('hidden', !append);

    try {
      let url;
      const headers = token ? { Authorization: `Bearer ${token}` } : {};

      if (currentTab === 'squads' && token) {
        renderSquadsView();
        isLoading = false;
        hasMore = false;
        scrollSentinel.classList.add('hidden');
        return;
      } else if (currentTab === 'timeline' && token) {
        url = `${hubUrl}/api/timeline?page=${currentPage}`;
      } else if (currentTab === 'bluesky' && token) {
        // Get browser-side Bluesky session, use hub as thin proxy (server-to-server to bsky.social)
        const session = await ensureBskySession();
        console.log('[PS] Bluesky session:', session ? 'got accessJwt' : 'NONE');
        if (!session?.accessJwt) {
          feedContainer.innerHTML = `<div class="text-center py-8 text-theme-faint">${L.connectBluesky}</div>`;
          isLoading = false;
          hasMore = false;
          scrollSentinel.classList.add('hidden');
          return;
        }
        try {
          let proxyUrl = `${hubUrl}/api/bluesky-feed/proxy/timeline?limit=20`;
          if (bskyCursor) proxyUrl += `&cursor=${encodeURIComponent(bskyCursor)}`;
          console.log('[PS] Fetching timeline via hub proxy...');
          const res = await fetch(proxyUrl, {
            headers: { 'Authorization': `Bearer ${session.accessJwt}` },
          });
          console.log('[PS] Proxy response:', res.status);
          if (res.ok) {
            const raw = await res.json();
            const posts = (raw.feed || []).map(item => normalizeBskyPostClient(item));
            renderBskyPosts({ posts, cursor: raw.cursor || null }, append);
            return;
          }
          const errBody = await res.text().catch(() => '');
          console.error('[PS] Proxy error body:', errBody);
          // If 401/expired, refresh and retry once
          if (res.status === 401 || res.status === 400) {
            console.log('[PS] Token expired, refreshing...');
            const refreshed = await refreshBskySession();
            if (refreshed?.accessJwt) {
              const retry = await fetch(proxyUrl, {
                headers: { 'Authorization': `Bearer ${refreshed.accessJwt}` },
              });
              if (retry.ok) {
                const raw = await retry.json();
                const posts = (raw.feed || []).map(item => normalizeBskyPostClient(item));
                renderBskyPosts({ posts, cursor: raw.cursor || null }, append);
                return;
              }
            }
          }
        } catch (err) {
          console.error('[PS] Proxy error:', err.message);
        }
        feedContainer.innerHTML = `<div class="text-center py-8 text-red-400">${L.failedToLoad}</div>`;
        isLoading = false;
        hasMore = false;
        scrollSentinel.classList.add('hidden');
        return;
      } else if (currentTab === 'discover' || (currentTab === 'timeline' && !token)) {
        url = `${hubUrl}/api/timeline/discover?page=${currentPage}`;
      } else if (currentTab === 'people') {
        url = `${hubUrl}/api/directory?page=${currentPage}`;
        const res = await fetchWithTimeout(url, { headers });
        const data = await res.json();
        renderPeople(data, append);
        isLoading = false;
        scrollSentinel.classList.toggle('hidden', !hasMore);
        return;
      }

      const res = await fetchWithTimeout(url, { headers });
      const data = await res.json();
      renderPosts(data, append);
    } catch (err) {
      if (!append) feedContainer.innerHTML = `<div class="text-center py-8 text-red-400">${L.failedToLoad}</div>`;
      hasMore = false;
    } finally {
      isLoading = false;
      scrollSentinel.classList.toggle('hidden', !hasMore);
    }
  }

  function renderPosts(data, append) {
    const html = (data.posts || []).map(post => {
      const isExternal = post.source === 'external';

      // Author line: Pirate user or external feed info
      const authorHtml = isExternal
        ? `<div class="flex items-center gap-2">
            ${post.feed?.iconUrl ? `<img src="${escapeHtml(post.feed.iconUrl)}" class="h-8 w-8 rounded" onerror="this.style.display='none'" />` : '<div class="h-8 w-8 rounded bg-theme-surface-hover flex items-center justify-center text-theme-muted text-xs">RSS</div>'}
            <div>
              <span class="font-medium text-sm">${escapeHtml(post.feed?.title || post.author || 'External')}</span>
              <span class="ml-2 text-xs px-1.5 py-0.5 rounded bg-theme-input-bg text-theme-muted">RSS</span>
              <time class="block text-xs text-theme-faint">${new Date(post.pubDate).toLocaleDateString()}</time>
            </div>
          </div>`
        : `<div class="flex items-center gap-3">
            ${post.user?.avatarUrl ? `<img src="${escapeHtml(post.user.avatarUrl)}" class="h-8 w-8 rounded-full" />` : ''}
            <div>
              <a href="${hubUrl}/../${escapeHtml(post.user?.username || '')}" class="font-medium text-sm hover:underline">${escapeHtml(post.user?.displayName || post.user?.username || 'Unknown')}</a>
              <time class="block text-xs text-theme-faint">${new Date(post.pubDate).toLocaleDateString()}</time>
            </div>
          </div>`;

      // Interaction bar: only Pirate posts have likes/comments
      const shareBtn = `<button class="share-btn hover:text-green-500 transition" data-url="${escapeHtml(post.link || '')}" data-title="${escapeHtml(post.title || '')}">${L.shareButton}</button>`;
      const actionsHtml = isExternal
        ? `<a href="${escapeHtml(post.link)}" target="_blank" rel="noopener noreferrer" class="hover:text-theme-text">${L.readButton}</a>${shareBtn}`
        : `<button class="like-btn hover:text-red-400 transition ${post.hasLiked ? 'text-red-400' : ''}" data-post-id="${post.id}">
              ${post.hasLiked ? '♥' : '♡'} ${post.likeCount || post._count?.likes || 0}
            </button>
            <button class="comment-btn hover:text-theme-primary transition" data-post-id="${post.id}">
              💬 ${post.commentCount || post._count?.comments || 0}
            </button>
            ${shareBtn}
            ${post.link ? `<a href="${escapeHtml(post.link)}" target="_blank" class="hover:text-theme-text ml-auto">${L.viewButton}</a>` : ''}`;

      // Build embed HTML for rich content (Bluesky images, videos, link cards, quotes)
      const embed = post.embedData || {};
      let embedHtml = '';

      // Multiple images (gallery grid)
      if (embed.images?.length > 1) {
        embedHtml += `<div class="grid grid-cols-2 gap-1 mt-2 rounded overflow-hidden">
          ${embed.images.map(img => `<img src="${escapeHtml(img.fullsize || img.thumb)}" alt="${escapeHtml(img.alt)}" class="w-full object-cover aspect-square" loading="lazy" onerror="this.style.display='none'" />`).join('')}
        </div>`;
      }

      // Video
      if (embed.video?.playlist) {
        embedHtml += `<div class="mt-2 rounded overflow-hidden bg-black aspect-video relative">
          <video controls preload="none" poster="${escapeHtml(embed.video.thumb || '')}" class="w-full h-full" data-hls="${escapeHtml(embed.video.playlist)}"></video>
        </div>`;
      }

      // External link card
      if (embed.external?.uri) {
        const ytId = getYouTubeId(embed.external.uri);
        if (ytId) {
          embedHtml += `<div class="mt-2 rounded overflow-hidden bg-black aspect-video"><iframe src="https://www.youtube.com/embed/${ytId}" class="w-full h-full" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe></div>`;
        } else {
          embedHtml += `<a href="${escapeHtml(embed.external.uri)}" target="_blank" rel="noopener noreferrer" class="mt-2 block rounded border border-theme-input-border overflow-hidden hover:border-theme-card-hover transition">
            ${embed.external.thumb ? `<img src="${escapeHtml(embed.external.thumb)}" alt="" class="w-full aspect-[2/1] object-cover" loading="lazy" onerror="this.style.display='none'" />` : ''}
            <div class="p-3">
              <div class="text-sm font-medium text-theme-text line-clamp-1">${escapeHtml(embed.external.title || '')}</div>
              ${embed.external.description ? `<div class="text-xs text-theme-faint mt-1 line-clamp-2">${escapeHtml(embed.external.description)}</div>` : ''}
              <div class="text-xs text-theme-faint mt-1">${escapeHtml(new URL(embed.external.uri).hostname)}</div>
            </div>
          </a>`;
        }
      }

      // Quote post
      if (embed.quote?.text) {
        embedHtml += `<div class="mt-2 rounded border border-theme-input-border p-3 bg-theme-surface/50">
          <div class="text-xs text-theme-muted mb-1">
            <span class="font-medium text-theme-text">${escapeHtml(embed.quote.author)}</span>
            <span class="text-theme-faint ml-1">@${escapeHtml(embed.quote.handle)}</span>
          </div>
          <p class="text-sm text-theme-text line-clamp-4">${escapeHtml(embed.quote.text)}</p>
        </div>`;
      }

      // Primary image: use single embed image or imageUrl (skip if we showed a gallery above)
      const primaryImage = (embed.images?.length === 1)
        ? embed.images[0].fullsize || embed.images[0].thumb
        : (!embed.images?.length ? post.imageUrl : null);

      return `
        <article class="rounded-lg border border-theme-card-border bg-theme-card overflow-hidden">
          ${primaryImage ? `<div class="bg-black flex justify-center"><img src="${escapeHtml(primaryImage)}" alt="${escapeHtml(embed.images?.[0]?.alt || post.title)}" style="width:100%;max-height:28rem;object-fit:contain" loading="lazy" onerror="this.parentElement.style.display='none'" /></div>` : ''}
          <div class="p-4">
            <div class="mb-3">${authorHtml}</div>
            <h3 class="font-semibold"><a href="${escapeHtml(post.link)}" target="_blank" class="hover:underline">${formatText(post.title)}</a></h3>
            ${post.description && post.description !== post.title ? `<p class="mt-1 text-sm text-theme-muted">${formatText(post.description)}</p>` : ''}
            ${embedHtml}
            ${post.exifData ? `<div class="mt-2 text-xs text-theme-faint">${formatExif(post.exifData)}</div>` : ''}
            <div class="mt-3 flex items-center gap-4 text-sm text-theme-muted">
              ${actionsHtml}
            </div>
          </div>
        </article>
      `;
    }).join('');

    if (append) {
      feedContainer.insertAdjacentHTML('beforeend', html);
    } else {
      feedContainer.innerHTML = html || `<div class="text-center py-8 text-theme-faint">${L.noPosts}</div>`;
    }

    hasMore = !!data.hasMore;
    attachInteractionListeners();
    attachShareListeners();
    initHlsVideos();
  }

  function renderBskyPosts(data, append) {
    const posts = data.posts || [];
    bskyCursor = data.cursor || null;

    const html = posts.map(post => {
      const embed = post.embedData || {};
      let embedHtml = '';

      // Multiple images
      if (embed.images?.length > 1) {
        embedHtml += `<div class="grid grid-cols-2 gap-1 mt-2 rounded overflow-hidden">
          ${embed.images.map(img => `<img src="${escapeHtml(img.fullsize || img.thumb)}" alt="${escapeHtml(img.alt || '')}" class="w-full object-cover aspect-square" loading="lazy" onerror="this.style.display='none'" />`).join('')}
        </div>`;
      }

      // Single image
      if (embed.images?.length === 1) {
        embedHtml += `<div class="mt-2 bg-black flex justify-center rounded overflow-hidden"><img src="${escapeHtml(embed.images[0].fullsize || embed.images[0].thumb)}" alt="${escapeHtml(embed.images[0].alt || '')}" style="width:100%;max-height:28rem;object-fit:contain" loading="lazy" onerror="this.parentElement.style.display='none'" /></div>`;
      }

      // Video
      if (embed.video?.playlist) {
        embedHtml += `<div class="mt-2 rounded overflow-hidden bg-black aspect-video">
          <video controls preload="none" poster="${escapeHtml(embed.video.thumb || '')}" class="w-full h-full" data-hls="${escapeHtml(embed.video.playlist)}"></video>
        </div>`;
      }

      // External link card
      if (embed.external?.uri) {
        const ytId = getYouTubeId(embed.external.uri);
        if (ytId) {
          embedHtml += `<div class="mt-2 rounded overflow-hidden bg-black aspect-video"><iframe src="https://www.youtube.com/embed/${ytId}" class="w-full h-full" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe></div>`;
        } else {
          embedHtml += `<a href="${escapeHtml(embed.external.uri)}" target="_blank" rel="noopener noreferrer" class="mt-2 block rounded border border-theme-input-border overflow-hidden hover:border-theme-card-hover transition">
            ${embed.external.thumb ? `<img src="${escapeHtml(embed.external.thumb)}" alt="" class="w-full aspect-[2/1] object-cover" loading="lazy" onerror="this.style.display='none'" />` : ''}
            <div class="p-3">
              <div class="text-sm font-medium text-theme-text line-clamp-1">${escapeHtml(embed.external.title || '')}</div>
              ${embed.external.description ? `<div class="text-xs text-theme-faint mt-1 line-clamp-2">${escapeHtml(embed.external.description)}</div>` : ''}
            </div>
          </a>`;
        }
      }

      // Quote
      if (embed.quote?.text) {
        embedHtml += `<div class="mt-2 rounded border border-theme-input-border p-3 bg-theme-surface/50">
          <div class="text-xs text-theme-muted mb-1">
            <span class="font-medium text-theme-text">${escapeHtml(embed.quote.author)}</span>
            <span class="text-theme-faint ml-1">@${escapeHtml(embed.quote.handle)}</span>
          </div>
          <p class="text-sm text-theme-text line-clamp-4">${escapeHtml(embed.quote.text)}</p>
        </div>`;
      }

      const repostLine = post.repostBy
        ? `<div class="text-xs text-theme-faint mb-2">🔁 Reposted by ${escapeHtml(post.repostBy.displayName)}</div>`
        : '';

      return `
        <article class="rounded-lg border border-theme-card-border bg-theme-card overflow-hidden">
          <div class="p-4">
            ${repostLine}
            <div class="flex items-center gap-3 mb-3">
              ${post.author.avatar ? `<img src="${escapeHtml(post.author.avatar)}" class="h-10 w-10 rounded-full" />` : '<div class="h-10 w-10 rounded-full bg-theme-surface-hover"></div>'}
              <div>
                <a href="https://bsky.app/profile/${escapeHtml(post.author.handle)}" target="_blank" class="font-medium text-sm hover:underline">${escapeHtml(post.author.displayName)}</a>
                <div class="text-xs text-theme-faint">@${escapeHtml(post.author.handle)}</div>
              </div>
              <time class="text-xs text-theme-faint ml-auto">${new Date(post.pubDate).toLocaleDateString()}</time>
            </div>
            ${post.text ? `<p class="text-sm whitespace-pre-wrap mb-2">${formatText(post.text)}</p>` : ''}
            ${embedHtml}
            <div class="mt-3 flex items-center gap-4 text-xs text-theme-faint">
              <span>♡ ${post.likeCount}</span>
              <span>🔁 ${post.repostCount}</span>
              <span>💬 ${post.replyCount}</span>
              <button class="share-btn hover:text-green-500 transition ml-auto" data-url="${escapeHtml(post.link)}" data-title="${escapeHtml(post.text?.slice(0, 100) || '')}">${L.shareButton}</button>
              <a href="${escapeHtml(post.link)}" target="_blank" rel="noopener noreferrer" class="hover:text-theme-text">↗ Open</a>
            </div>
          </div>
        </article>
      `;
    }).join('');

    if (append) {
      feedContainer.insertAdjacentHTML('beforeend', html);
    } else {
      feedContainer.innerHTML = html || `<div class="text-center py-8 text-theme-faint">${L.connectBluesky}</div>`;
    }

    hasMore = !!bskyCursor;
    isLoading = false;
    scrollSentinel.classList.toggle('hidden', !hasMore);
    attachShareListeners();
    initHlsVideos();
  }

  function renderPeople(data, append) {
    const html = (data.users || []).map(user => `
      <div class="flex items-center gap-4 rounded-lg border border-theme-card-border bg-theme-card p-4">
        ${user.avatarUrl ? `<img src="${escapeHtml(user.avatarUrl)}" class="h-12 w-12 rounded-full" />` : '<div class="h-12 w-12 rounded-full bg-theme-surface-hover"></div>'}
        <div class="flex-1 min-w-0">
          <a href="${escapeHtml(user.siteUrl || '#')}" target="_blank" class="font-medium hover:underline">${escapeHtml(user.displayName || user.username)}</a>
          <p class="text-sm text-theme-muted">@${escapeHtml(user.username)}</p>
          ${user.bio ? `<p class="text-sm text-theme-faint mt-1 truncate">${escapeHtml(user.bio)}</p>` : ''}
        </div>
        <div class="text-right text-xs text-theme-faint">
          <div>${user._count?.posts || 0} posts</div>
          <div>${user._count?.followers || 0} followers</div>
        </div>
        ${token ? `<button class="follow-btn rounded bg-theme-surface-hover px-3 py-1 text-xs hover:bg-theme-card-hover transition" data-user-id="${user.id}">Follow</button>` : ''}
      </div>
    `).join('');

    if (append) {
      feedContainer.insertAdjacentHTML('beforeend', html);
    } else {
      feedContainer.innerHTML = html || `<div class="text-center py-8 text-theme-faint">${L.noUsers}</div>`;
    }

    hasMore = !!data.hasMore;
    attachInteractionListeners();
    attachShareListeners();
    initHlsVideos();
  }

  function attachInteractionListeners() {
    document.querySelectorAll('.like-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!token) return alert('Sign in to like posts');
        const postId = btn.dataset.postId;
        const isLiked = btn.textContent.includes('♥');
        const method = isLiked ? 'DELETE' : 'POST';
        const res = await fetch(`${hubUrl}/api/interactions/like`, {
          method, headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ postId }),
        });
        const data = await res.json();
        btn.innerHTML = `${data.liked ? '♥' : '♡'} ${data.count}`;
        btn.classList.toggle('text-red-400', data.liked);
      });
    });

    document.querySelectorAll('.follow-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!token) return;
        const userId = btn.dataset.userId;
        const res = await fetch(`${hubUrl}/api/interactions/follow`, {
          method: 'POST', headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId }),
        });
        const data = await res.json();
        btn.textContent = data.following ? 'Following' : 'Follow';
      });
    });
  }

  function formatExif(exif) {
    const parts = [];
    if (exif.camera) parts.push(exif.camera);
    if (exif.lens) parts.push(exif.lens);
    if (exif.focalLength) parts.push(exif.focalLength);
    if (exif.aperture) parts.push(`f/${exif.aperture}`);
    if (exif.shutterSpeed) parts.push(`${exif.shutterSpeed}s`);
    if (exif.iso) parts.push(`ISO ${exif.iso}`);
    return parts.join(' · ');
  }

  function escapeHtml(str) {
    if (!str) return '';
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function formatText(str) {
    if (!str) return '';
    // Decode XML newline entities, strip Bluesky embed placeholders
    let text = str
      .replace(/&#xA;/gi, '\n')
      .replace(/\[contains quote post or other embedded content\]/gi, '')
      .trim();
    return escapeHtml(text).replace(/\n/g, '<br>');
  }



  // --- Share modal ---
